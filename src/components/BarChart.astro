---
// Reusable horizontal bar chart for inline use in posts.
// Renders as real HTML/CSS (crawlable, works with no JS). A tiny island
// animates bars in on scroll and shows values on hover.
//
// Usage (in an .mdx post):
//   import BarChart from '../../components/BarChart.astro';
//   <BarChart
//     title="Terminal-Bench 2.1 score"
//     caption="Higher is better. Source: published benchmarks, June 2026."
//     unit=""
//     data={[
//       { label: 'Claude Opus 4.8', value: 85.0 },
//       { label: 'GLM-5.2', value: 81.0, highlight: true },
//       { label: 'Gemini 3.1 Pro', value: 78.0 },
//     ]}
//   />

interface Bar {
	label: string;
	value: number;
	/** Optional text shown instead of the raw number (e.g. "$1.40"). */
	display?: string;
	/** Emphasize this bar (the subject of the post). */
	highlight?: boolean;
}

interface Props {
	title?: string;
	caption?: string;
	/** Appended to numeric labels, e.g. "%" or "x". Ignored if a bar sets `display`. */
	unit?: string;
	/** Override the axis max; defaults to the largest value. */
	max?: number;
	data: Bar[];
}

const { title, caption, unit = '', max, data } = Astro.props;
const axisMax = max ?? Math.max(...data.map((d) => d.value));
const fmt = (b: Bar) => b.display ?? `${b.value}${unit}`;
---

<figure class="my-8 not-prose" data-barchart>
	{title && (
		<figcaption class="text-sm font-medium text-zinc-300 mb-4 tracking-tight">{title}</figcaption>
	)}
	<div class="space-y-3" role="img" aria-label={title}>
		{data.map((bar) => {
			const pct = Math.max(2, Math.round((bar.value / axisMax) * 100));
			return (
				<div class="grid grid-cols-[7.5rem_1fr] sm:grid-cols-[9rem_1fr] items-center gap-3 text-sm group">
					<span class={`truncate text-right ${bar.highlight ? 'text-zinc-50 font-medium' : 'text-zinc-400'}`}>
						{bar.label}
					</span>
					<div class="relative h-7 rounded-md bg-zinc-900/70 overflow-hidden">
						<div
							class={`bar absolute inset-y-0 left-0 rounded-md transition-[width] duration-700 ease-out ${
								bar.highlight ? 'bg-zinc-100' : 'bg-zinc-700'
							}`}
							style={`width: 0%;`}
							data-target={pct}
						>
						</div>
						<span
							class={`absolute inset-y-0 right-2.5 flex items-center text-xs font-medium tabular-nums ${
								bar.highlight ? 'text-zinc-900' : 'text-zinc-300'
							} group-hover:text-zinc-50 transition-colors`}
							style={bar.highlight ? '' : 'text-shadow: 0 1px 2px rgba(0,0,0,0.6);'}
						>
							{fmt(bar)}
						</span>
					</div>
				</div>
			);
		})}
	</div>
	{caption && (
		<figcaption class="mt-4 text-xs text-zinc-500 leading-relaxed">{caption}</figcaption>
	)}
</figure>

<script>
	// Animate each chart's bars to their target width when it scrolls into view.
	function initBarCharts() {
		const charts = document.querySelectorAll('[data-barchart]');
		if (!charts.length) return;

		const animate = (chart: Element) => {
			chart.querySelectorAll<HTMLElement>('.bar').forEach((bar) => {
				const target = bar.getAttribute('data-target') || '0';
				requestAnimationFrame(() => {
					bar.style.width = target + '%';
				});
			});
		};

		if (!('IntersectionObserver' in window)) {
			charts.forEach(animate);
			return;
		}

		const io = new IntersectionObserver(
			(entries, obs) => {
				entries.forEach((entry) => {
					if (entry.isIntersecting) {
						animate(entry.target);
						obs.unobserve(entry.target);
					}
				});
			},
			{ threshold: 0.35 }
		);
		charts.forEach((c) => io.observe(c));
	}

	initBarCharts();
	document.addEventListener('astro:after-swap', initBarCharts);
</script>
